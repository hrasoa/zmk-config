#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

#define DEFAULT 0
#define LOWER   1
#define RAISE   2
#define MO_TO(layer) &mo_to layer layer

/ {
    behaviors {
        mo_to: behavior_mo_to {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            bindings = <&mo>, <&to>;
        };

        mo_to_morph: behavior_mo_to_morph {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <MO_TO(LOWER)>, <MO_TO(RAISE)>;
            mods = <(MOD_RGUI)>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                // ╭──────────┬──────────┬──────────┬──────────┬──────────┬──────────╮   ╭──────────┬──────────┬──────────┬──────────┬──────────┬──────────╮
                // │          │          │          │          │          │          │   │          │          │          │          │          │          │
                // │          │  Q       │  W       │  E       │  R       │  T       │   │  Y       │  U       │  I       │  O       │  P       │  ESC     │
                      &none      &kp Q      &kp W      &kp E      &kp R      &kp T          &kp Y     &kp U       &kp I      &kp O      &kp P      &kp ESC
                // ├──────────┼──────────┼──────────┼──────────┼──────────┤──────────┤   ├──────────┼──────────┼──────────┼──────────┼──────────┼──────────┤
                // │          │          │          │          │          │          │   │          │          │          │          │  :       │          │
                // │  TAB     │  A       │  S       │  D       │  F       │  G       │   │  H       │  J       │  K       │  L       │  ;    …  │  BKSP    │
                   &kp TAB       &kp A   &mt LCTRL S   &kp D   &mt LGUI F    &kp G          &kp H   &mt RGUI J    &kp K   &mt LCTRL L   &kp SEMI   &kp BSPC
                // ├──────────┼──────────┼──────────┼──────────┼──────────┤──────────┤   ├──────────┼──────────┼──────────┼──────────┼──────────┼──────────┤
                // │          │          │          │          │          │          │   │          │          │  LT      │  GT      │  ?       │          │
                // │  LSHIFT  │  Z       │  X       │  C       │  V       │  B       │   │  N       │  M       │  ,    ≤  │  .    ≥  │  /       │  RSHIFT  │
                   &kp LSHFT     &kp Z      &kp X      &kp C      &kp V      &kp B          &kp N      &kp M   &kp COMMA  &kp DOT    &kp FSLH   &kp RSHIFT
                // ╰──────────┴──────────┴──────────┼──────────┼──────────┤──────────┤   ├──────────┼──────────┼──────────┼──────────┴──────────┴──────────╯
                                                       &none   &kp LALT   &kp SPACE      &kp RET    &mo_to_morph  &none
                //                                  ╰──────────┴──────────┴──────────╯   ╰──────────┴──────────┴──────────╯
            >;
        };

        lower_layer {
            bindings = <
                // ╭──────────┬──────────┬──────────┬──────────┬──────────┬──────────╮   ╭──────────┬──────────┬──────────┬──────────┬──────────┬──────────╮
                // │          │          │          │          │          │          │   │          │          │          │          │          │          │
                // │  ▼       │  !       │  @       │  #       │  $       │  %       │   │  ^       │  &       │  *       │  (       │  )       │  ▼       │
                      &trans     &kp EXCL   &kp AT     &kp HASH   &kp DLLR   &kp PRCNT   &kp CARET  &kp AMPS   &kp ASTRK  &kp LPAR   &kp RPAR      &trans
                // ├──────────┼──────────┼──────────┼──────────┼──────────┤──────────┤   ├──────────┼──────────┼──────────┼──────────┼──────────┼──────────┤
                // │          │          │          │          │          │          │   │  _       │  +       │          │  {       │  }       │          │
                // │  ▼       │  1       │  2    €  │  3       │  4       │  5       │   │  -       │  =       │  GT      │  [       │  ]       │  ▼       │
                      &trans     &kp N1  &mt LCTRL N2 &kp N3  &mt LGUI N4   &kp N5      &kp MINUS  &mt RGUI EQUAL &kp GT &mt LCTRL LBKT &kp RBKT  &trans
                // ├──────────┼──────────┼──────────┼──────────┼──────────┤──────────┤   ├──────────┼──────────┼──────────┼──────────┼──────────┼──────────┤
                // │          │          │          │          │          │          │   │  ~       │  "       │  |       │          │          │          │
                // │  ▼       │  6       │  7       │  8       │  9       │  0       │   │  `       │  '       │  \       │  {       │  }       │  ▼       │
                      &trans     &kp N6     &kp N7     &kp N8     &kp N9     &kp N0      &kp GRAVE  &kp APOS   &kp NUBS   &kp LBRC   &kp RBRC      &trans
                // ╰──────────┴──────────┴──────────┼──────────┼──────────┤──────────┤   ├──────────┼──────────┼──────────┼──────────┴──────────┴──────────╯
                                                       &trans     &trans     &trans         &trans  MO_TO(RAISE)  &trans  
                //                                  ╰──────────┴──────────┴──────────╯   ╰──────────┴──────────┴──────────╯
            >;
        };

        raise_layer {
            bindings = <
                // ╭──────────┬──────────┬──────────┬──────────┬──────────┬──────────╮   ╭──────────┬──────────┬──────────┬──────────┬──────────┬──────────╮
                // │          │          │          │          │          │          │   │          │          │          │          │          │          │
                // │  ▼       │          │  F2      │  CMD(E)  │  F4      │  F12     │   │          │          │  CMD(K)  │  CMD(I)  │          │  ▼       │
                      &trans     &none      &kp F2  &kp LG(E)     &kp F4     &kp F12        &none      &none   &kp LG(K)  &kp LG(I)     &none      &trans
                // ├──────────┼──────────┼──────────┼──────────┼──────────┤──────────┤   ├──────────┼──────────┼──────────┼──────────┼──────────┼──────────┤
                // │          │          │          │          │          │          │   │          │          │          │          │          │          │
                // │  ▼       │          │          │  CMD(D)  │  CMD(F)  │          │   │          │  LEFT    │  DOWN    │  UP      │  RIGHT   │  ▼       │
                      &trans     &none      &none   &kp LG(D)  &mt LGUI LG(F) &none          &none   &kp LEFT   &kp DOWN      &kp UP  &kp RIGHT     &trans
                // ├──────────┼──────────┼──────────┼──────────┼──────────┤──────────┤   ├──────────┼──────────┼──────────┼──────────┼──────────┼──────────┤
                // │          │          │          │          │          │          │   │          │          │          │          │          │          │
                // │  ▼       │  UNDO    │  CUT     │  COPY    │  PASTE   │  CMD(B)  │   │          │          │          │          │          │  ▼       │
                      &trans  &kp LG(Z)  &kp LG(X)  &kp LG(C)  &kp LG(V)  &kp LG(B)         &none      &none      &none     &none      &none      &trans
                // ╰──────────┴──────────┴──────────┼──────────┼──────────┤──────────┤   ├──────────┼──────────┼──────────┼──────────┴──────────┴──────────╯
                                                       &trans     &trans     &trans         &trans  &to DEFAULT   &trans  
                //                                  ╰──────────┴──────────┴──────────╯   ╰──────────┴──────────┴──────────╯
            >;
        };
    };
};